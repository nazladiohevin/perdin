<aside
  :class="sidebarToggle ? 'translate-x-0 lg:w-[90px]' : '-translate-x-full'"
  class="sidebar fixed left-0 top-0 z-9999 flex h-screen w-[290px] flex-col overflow-y-hidden border-r border-gray-200 bg-white px-5 dark:border-gray-800 dark:bg-black lg:static lg:translate-x-0"
>
  <!-- SIDEBAR HEADER -->
  <div
    :class="sidebarToggle ? 'justify-center' : 'justify-between'"
    class="flex items-center gap-2 pt-8 sidebar-header pb-7"
  >
    <a href="/">
      <span class="logo flex items-center gap-2.5" :class="sidebarToggle ? 'hidden' : ''">
        <img class="h-8 w-8" src="./images/logo/logo.png" alt="Logo" />
        <span class="text-xl font-bold text-gray-800 dark:text-white">PerdinKu</span>
      </span>

      <img
        class="logo-icon h-8 w-8"
        :class="sidebarToggle ? 'lg:block' : 'hidden'"
        src="./images/logo/logo.png"
        alt="Logo"
      />
    </a>
  </div>
  <!-- SIDEBAR HEADER -->

  <div
    class="flex flex-col overflow-y-auto duration-300 ease-linear no-scrollbar"
  >
    <nav x-data="{selected: $persist('Dashboard')}">
      <!-- Menu Group -->
      <div>
        <h3 class="mb-4 text-xs uppercase leading-[20px] text-gray-400">
          <span
            class="menu-group-title"
            :class="sidebarToggle ? 'lg:hidden' : ''"
          >
            MENU
          </span>

          <svg
            :class="sidebarToggle ? 'lg:block hidden' : 'hidden'"
            class="mx-auto fill-current menu-group-icon"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              fill-rule="evenodd"
              clip-rule="evenodd"
              d="M5.99915 10.2451C6.96564 10.2451 7.74915 11.0286 7.74915 11.9951V12.0051C7.74915 12.9716 6.96564 13.7551 5.99915 13.7551C5.03265 13.7551 4.24915 12.9716 4.24915 12.0051V11.9951C4.24915 11.0286 5.03265 10.2451 5.99915 10.2451ZM17.9991 10.2451C18.9656 10.2451 19.7491 11.0286 19.7491 11.9951V12.0051C19.7491 12.9716 18.9656 13.7551 17.9991 13.7551C17.0326 13.7551 16.2491 12.9716 16.2491 12.0051V11.9951C16.2491 11.0286 17.0326 10.2451 17.9991 10.2451ZM13.7491 11.9951C13.7491 11.0286 12.9656 10.2451 11.9991 10.2451C11.0326 10.2451 10.2491 11.0286 10.2491 11.9951V12.0051C10.2491 12.9716 11.0326 13.7551 11.9991 13.7551C12.9656 13.7551 13.7491 12.9716 13.7491 12.0051V11.9951Z"
              fill=""
            />
          </svg>
        </h3>

        <ul class="flex flex-col gap-4 mb-6">
          <!-- Menu Item Dashboard -->
          <li>
            <a
              href="/"
              @click="selected = (selected === 'Dashboard' ? '':'Dashboard')"
              class="menu-item group"
              :class="(selected === 'Dashboard') ? 'menu-item-active' : 'menu-item-inactive'"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" :class="(selected === 'Dashboard') ? 'menu-item-icon-active' : 'menu-item-icon-inactive'">
                <path d="M0 0h24v24H0z" fill="none" />
                <path fill="currentColor" d="M13 9V3h8v6zM3 13V3h8v10zm10 8V11h8v10zM3 21v-6h8v6z" />
              </svg>

              <span
                class="menu-item-text"
                :class="sidebarToggle ? 'lg:hidden' : ''"
              >
                Dashboard
              </span>
            </a>
          </li>

          <!-- Menu Item Pengajuan PerDin -->
          <li>
            <a
              href="/perdin"
              @click="selected = (selected === 'Pengajuan PerDin' ? '':'Pengajuan PerDin')"
              class="menu-item group"
              :class="(selected === 'Pengajuan PerDin') ? 'menu-item-active' : 'menu-item-inactive'"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" :class="(selected === 'Pengajuan PerDin') ? 'menu-item-icon-active' : 'menu-item-icon-inactive'">
                <path d="M0 0h24v24H0z" fill="none" />
                <path fill="currentColor" d="M17 20V7h2.385q.69 0 1.152.463T21 8.616v9.769q0 .69-.463 1.153T19.385 20zM10 7h4V5.615q0-.23-.192-.423T13.385 5h-2.77q-.23 0-.423.192T10 5.615zM8 20V7h1V5.615q0-.69.463-1.153T10.616 4h2.769q.69 0 1.153.462T15 5.615V7h1v13zm-3.384 0q-.691 0-1.153-.462T3 18.384V8.616q0-.691.463-1.153T4.615 7H7v13z" />
              </svg>

              <span
                class="menu-item-text"
                :class="sidebarToggle ? 'lg:hidden' : ''"
              >
                Pengajuan PerDin
              </span>
            </a>
          </li>

          <!-- Menu Item Master (with dropdown) -->
          <li>
            <a
              href="#"
              @click.prevent="selected = (selected === 'Master' ? '':'Master')"
              class="menu-item group"
              :class="(selected === 'Master') ? 'menu-item-active' : 'menu-item-inactive'"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" :class="(selected === 'Master') ? 'menu-item-icon-active' : 'menu-item-icon-inactive'">
                <path d="M0 0h24v24H0z" fill="none" />
                <g fill="none">
                  <path d="M3 21h18V3H3z" />
                  <path stroke="currentColor" stroke-width="2" d="M21 12v9H3v-9m18 0H3m18 0V3H3v9m3.998-4.5h.004v.004h-.004zm0 9h.004v.004h-.004z" />
                </g>
              </svg>

              <span
                class="menu-item-text"
                :class="sidebarToggle ? 'lg:hidden' : ''"
              >
                Master
              </span>

              <svg
                class="menu-item-arrow absolute right-2.5 top-1/2 -translate-y-1/2 stroke-current"
                :class="[(selected === 'Master') ? 'menu-item-arrow-active' : 'menu-item-arrow-inactive', sidebarToggle ? 'lg:hidden' : '' ]"
                width="20"
                height="20"
                viewBox="0 0 20 20"
                fill="none"
                xmlns="http://www.w3.org/2000/svg"
              >
                <path
                  d="M4.79175 7.39584L10.0001 12.6042L15.2084 7.39585"
                  stroke=""
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                />
              </svg>
            </a>

            <!-- Dropdown Menu Start -->
            <div
              class="overflow-hidden transform translate"
              :class="(selected === 'Master') ? 'block' :'hidden'"
            >
              <ul
                :class="sidebarToggle ? 'lg:hidden' : 'flex'"
                class="flex flex-col gap-1 mt-2 menu-dropdown pl-9"
              >
                <li>
                  <a
                    href="/users"
                    class="menu-dropdown-item group flex items-center gap-2"
                    :class="page === 'users' ? 'menu-dropdown-item-active' : 'menu-dropdown-item-inactive'"
                  >
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" class="opacity-70">
                      <path d="M0 0h24v24H0z" fill="none" />
                      <path fill="currentColor" d="M12 4a4 4 0 0 1 4 4a4 4 0 0 1-4 4a4 4 0 0 1-4-4a4 4 0 0 1 4-4m0 10c4.42 0 8 1.79 8 4v2H4v-2c0-2.21 3.58-4 8-4" />
                    </svg>
                    Pengguna
                  </a>
                </li>
                <li>
                  <a
                    href="/cities"
                    class="menu-dropdown-item group flex items-center gap-2"
                    :class="page === 'cities' ? 'menu-dropdown-item-active' : 'menu-dropdown-item-inactive'"
                  >
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 48 48" class="opacity-70">
                      <path d="M0 0h48v48H0z" fill="none" />
                      <defs>
                        <mask id="SVGh3nILcqj1">
                          <g fill="none">
                            <path stroke="#fff" stroke-linecap="round" stroke-linejoin="round" stroke-width="4" d="M4 42h40" />
                            <rect width="8" height="16" x="8" y="26" fill="#fff" stroke="#fff" stroke-linejoin="round" stroke-width="4" rx="2" />
                            <path stroke="#000" stroke-linecap="square" stroke-linejoin="round" stroke-width="4" d="M12 34h1" />
                            <rect width="24" height="38" x="16" y="4" fill="#fff" stroke="#fff" stroke-linejoin="round" stroke-width="4" rx="2" />
                            <path fill="#000" d="M22 10h4v4h-4zm8 0h4v4h-4zm-8 7h4v4h-4zm8 0h4v4h-4zm0 7h4v4h-4zm0 7h4v4h-4z" />
                          </g>
                        </mask>
                      </defs>
                      <path fill="currentColor" d="M0 0h48v48H0z" mask="url(#SVGh3nILcqj1)" />
                    </svg>
                    Kota
                  </a>
                </li>
                <li>
                  <a
                    href="/provinces"
                    class="menu-dropdown-item group flex items-center gap-2"
                    :class="page === 'provinces' ? 'menu-dropdown-item-active' : 'menu-dropdown-item-inactive'"
                  >
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 48 48" class="opacity-70">
                      <path d="M0 0h48v48H0z" fill="none" />
                      <defs>
                        <mask id="SVGh3nILcqj2">
                          <g fill="none">
                            <path stroke="#fff" stroke-linecap="round" stroke-linejoin="round" stroke-width="4" d="M4 42h40" />
                            <rect width="8" height="16" x="8" y="26" fill="#fff" stroke="#fff" stroke-linejoin="round" stroke-width="4" rx="2" />
                            <path stroke="#000" stroke-linecap="square" stroke-linejoin="round" stroke-width="4" d="M12 34h1" />
                            <rect width="24" height="38" x="16" y="4" fill="#fff" stroke="#fff" stroke-linejoin="round" stroke-width="4" rx="2" />
                            <path fill="#000" d="M22 10h4v4h-4zm8 0h4v4h-4zm-8 7h4v4h-4zm8 0h4v4h-4zm0 7h4v4h-4zm0 7h4v4h-4z" />
                          </g>
                        </mask>
                      </defs>
                      <path fill="currentColor" d="M0 0h48v48H0z" mask="url(#SVGh3nILcqj2)" />
                    </svg>
                    Provinsi
                  </a>
                </li>
                <li>
                  <a
                    href="/countries"
                    class="menu-dropdown-item group flex items-center gap-2"
                    :class="page === 'countries' ? 'menu-dropdown-item-active' : 'menu-dropdown-item-inactive'"
                  >
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" class="opacity-70">
                      <path d="M0 0h24v24H0z" fill="none" />
                      <path fill="currentColor" d="M12.003 21q-1.866 0-3.51-.708q-1.643-.709-2.859-1.924t-1.925-2.856T3 12.003t.709-3.51Q4.417 6.85 5.63 5.634t2.857-1.925T11.997 3t3.51.709q1.643.708 2.859 1.922t1.925 2.857t.709 3.509t-.708 3.51t-1.924 2.859t-2.856 1.925t-3.509.709M12 20q3.35 0 5.675-2.325T20 12q0-.175-.003-.353t-.022-.341q-.067.667-.53 1.104q-.464.436-1.137.436h-2.539q-.698 0-1.195-.496t-.497-1.193v-.845h-3.385v-1.69q0-.697.498-1.198q.497-.501 1.195-.501h.846v-.77q0-.728.476-1.146t1.137-.482q-.673-.26-1.38-.392T12 4Q8.65 4 6.325 6.325T4 12v.289q0 .134.02.288H8.5q1.42 0 2.402.983q.983.982.983 2.393v.855H9.346v2.73q.616.222 1.286.342T12 20" />
                    </svg>
                    Negara
                  </a>
                </li>
              </ul>
            </div>
            <!-- Dropdown Menu End -->
          </li>
          <!-- Menu Item Master -->
        </ul>
      </div>
    </nav>
  </div>
</aside>
