@using System.Threading

<div class="mb-5 rounded-xl border p-4 @(Type == "success" ? "border-success-300 bg-success-50 dark:border-success-500/30 dark:bg-success-500/15" : "border-error-500 bg-error-50 dark:border-error-500/30 dark:bg-error-500/15")">
    <div class="flex items-start justify-between gap-3">
        <div class="flex items-start gap-3">
            <div class="-mt-0.5 @(Type == "success" ? "text-success-500" : "text-error-500")">
                @if (Type == "success")
                {
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path fill-rule="evenodd" clip-rule="evenodd" d="M12 2C6.48 2 2 6.48 2 12C2 17.52 6.48 22 12 22C17.52 22 22 17.52 22 12C22 6.48 17.52 2 12 2ZM10 17L5 12L6.41 10.59L10 14.17L17.59 6.58L19 8L10 17Z" fill="currentColor"/>
                    </svg>
                }
                else
                {
                    <svg class="fill-current" width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path fill-rule="evenodd" clip-rule="evenodd" d="M20.3499 12.0004C20.3499 16.612 16.6115 20.3504 11.9999 20.3504C7.38832 20.3504 3.6499 16.612 3.6499 12.0004C3.6499 7.38881 7.38833 3.65039 11.9999 3.65039C16.6115 3.65039 20.3499 7.38881 20.3499 12.0004ZM11.9999 22.1504C17.6056 22.1504 22.1499 17.6061 22.1499 12.0004C22.1499 6.3947 17.6056 1.85039 11.9999 1.85039C6.39421 1.85039 1.8499 6.3947 1.8499 12.0004C1.8499 17.6061 6.39421 22.1504 11.9999 22.1504ZM13.0008 16.4753C13.0008 15.923 12.5531 15.4753 12.0008 15.4753L11.9998 15.4753C11.4475 15.4753 10.9998 15.923 10.9998 16.4753C10.9998 17.0276 11.4475 17.4753 11.9998 17.4753L12.0008 17.4753C12.5531 17.4753 13.0008 17.0276 13.0008 16.4753ZM11.9998 6.62898C12.414 6.62898 12.7498 6.96476 12.7498 7.37898L12.7498 13.0555C12.7498 13.4697 12.414 13.8055 11.9998 13.8055C11.5856 13.8055 11.2498 13.4697 11.2498 13.0555L11.2498 7.37898L11.2498 6.96476 11.5856 6.62898 11.9998 6.62898Z" fill="#F04438" />
                    </svg>
                }
            </div>
            <div>
                <h4 class="mb-1 text-sm font-semibold text-gray-800 dark:text-white/90">@(Title ?? (Type == "success" ? "Sukses" : "Terjadi Kesalahan"))</h4>
                <p class="text-sm text-gray-500 dark:text-gray-400">@Message</p>
            </div>
        </div>
        <button type="button" @onclick="Close" class="@(Type == "success" ? "text-success-400 hover:text-success-600 dark:text-success-400 dark:hover:text-success-300" : "text-error-400 hover:text-error-600 dark:text-error-400 dark:hover:text-error-300")">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M15 5L5 15M5 5L15 15" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
        </button>
    </div>
</div>

@code {
    [Parameter] public string Type { get; set; } = "success";
    [Parameter] public string? Title { get; set; }
    [Parameter] public string Message { get; set; } = string.Empty;
    [Parameter] public EventCallback OnClose { get; set; }

    private CancellationTokenSource? _cts;

    protected override void OnInitialized()
    {
        _cts = new CancellationTokenSource();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                await Task.Delay(5000, _cts?.Token ?? CancellationToken.None);
                await Close();
            }
            catch (TaskCanceledException)
            {
                // Silently ignore if canceled
            }
        }
    }

    private async Task Close()
    {
        _cts?.Cancel();
        await OnClose.InvokeAsync();
    }

    public void Dispose()
    {
        _cts?.Cancel();
        _cts?.Dispose();
    }
}
