@page "/cities"
@inject CityService CityService
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime
<PageTitle>Kota</PageTitle>

<div class="mb-6 flex items-center justify-between">
    <h2 class="text-lg font-semibold text-gray-800 dark:text-white/90">
        Kota
    </h2>
    <a href="/cities/create"
       class="inline-flex items-center gap-2 rounded-lg bg-brand-500 px-4 py-3 text-sm font-medium text-white shadow-theme-xs hover:bg-brand-600">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="12" y1="5" x2="12" y2="19"></line>
            <line x1="5" y1="12" x2="19" y2="12"></line>
        </svg>
        Buat Kota Baru
    </a>
</div>

@if (!string.IsNullOrEmpty(successMessage))
{
    <Alert Type="success" Message="@successMessage" OnClose="() => successMessage = string.Empty" />
}

@if (!string.IsNullOrEmpty(errorMessage))
{
    <Alert Type="error" Message="@errorMessage" OnClose="() => errorMessage = string.Empty" />
}

<div class="overflow-hidden rounded-xl border border-gray-200 bg-white dark:border-gray-800 dark:bg-white/[0.03]">
    <div class="max-w-full overflow-x-auto">
        <table class="min-w-full">
            <thead>
                <tr class="border-b border-gray-100 dark:border-gray-800">
                    <th class="px-5 py-3 sm:px-6">
                        <p class="text-left font-medium text-gray-500 text-theme-xs dark:text-gray-400">No</p>
                    </th>
                    <th class="px-5 py-3 sm:px-6">
                        <p class="text-left font-medium text-gray-500 text-theme-xs dark:text-gray-400">Nama</p>
                    </th>
                    <th class="px-5 py-3 sm:px-6">
                        <p class="text-left font-medium text-gray-500 text-theme-xs dark:text-gray-400">Provinsi</p>
                    </th>
                    <th class="px-5 py-3 sm:px-6">
                        <p class="text-left font-medium text-gray-500 text-theme-xs dark:text-gray-400">Dibuat Pada</p>
                    </th>
                    <th class="px-5 py-3 sm:px-6 text-right">
                        <p class="text-right font-medium text-gray-500 text-theme-xs dark:text-gray-400">Action</p>
                    </th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-100 dark:divide-gray-800">
                @if (isLoading)
                {
                    <tr>
                        <td colspan="5" class="px-5 py-8 text-center text-gray-500">
                            <span class="inline-block h-6 w-6 animate-spin rounded-full border-2 border-solid border-brand-500 border-t-transparent"></span>
                            <span class="ml-2">Memuat data...</span>
                        </td>
                    </tr>
                }
                else if (cities.Count == 0)
                {
                    <tr>
                        <td colspan="5" class="px-5 py-8 text-center text-gray-500">
                            Tidak ada data kota.
                        </td>
                    </tr>
                }
                else
                {
                    int index = 1;
                    @foreach (var city in cities)
                    {
                        var currentCity = city;
                        var currentIndex = index++;
                        <tr>
                            <td class="px-5 py-4 sm:px-6">
                                <p class="text-gray-500 text-theme-sm dark:text-gray-400">@currentIndex</p>
                            </td>
                            <td class="px-5 py-4 sm:px-6">
                                <p class="font-medium text-gray-800 text-theme-sm dark:text-white/90">@currentCity.Name</p>
                            </td>
                            <td class="px-5 py-4 sm:px-6">
                                <p class="text-gray-500 text-theme-sm dark:text-gray-400">@(currentCity.Province?.Name ?? "Tidak Diketahui")</p>
                            </td>
                            <td class="px-5 py-4 sm:px-6">
                                <p class="text-gray-500 text-theme-sm dark:text-gray-400">@FormatCreatedAt(currentCity.CreatedAt)</p>
                            </td>
                            <td class="px-5 py-4 sm:px-6 text-right">
                                <div class="flex items-center justify-end gap-3">
                                    <a href="/cities/@currentCity.Id" class="text-gray-500 hover:text-brand-500 dark:text-gray-400 dark:hover:text-brand-400" title="Detail">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg>
                                    </a>
                                    <a href="/cities/@currentCity.Id/edit" class="text-gray-500 hover:text-brand-500 dark:text-gray-400 dark:hover:text-brand-400" title="Edit">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path></svg>
                                    </a>
                                    <button type="button" @onclick="() => PromptDelete(currentCity.Id, currentCity.Name)" class="text-gray-500 hover:text-error-500 dark:text-gray-400 dark:hover:text-error-400" title="Delete">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path></svg>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

<ConfirmDeleteModal
    Visible="showDeleteModal"
    Message="@deleteConfirmMessage"
    IsLoading="isDeleting"
    OnCancel="CancelDelete"
    OnConfirm="ConfirmDelete" />

@code {
    [Parameter]
    [SupplyParameterFromQuery(Name = "success")]
    public string? Success { get; set; }

    private bool isLoading = true;
    private List<CityListItem> cities = new();
    private string successMessage = string.Empty;
    private string errorMessage = string.Empty;

    // Delete confirmation state
    private bool showDeleteModal = false;
    private int deleteTargetId;
    private string deleteConfirmMessage = string.Empty;
    private bool isDeleting = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    protected override void OnParametersSet()
    {
        if (!string.IsNullOrEmpty(Success))
        {
            successMessage = Success;
        }
    }

    private async Task LoadData()
    {
        isLoading = true;
        errorMessage = string.Empty;
        StateHasChanged();

        try
        {
            var result = await CityService.GetListAsync(includeProvince: true);
            if (result.Success && result.Data != null)
            {
                cities = result.Data;
            }
            else
            {
                errorMessage = result.Message;
            }
        }
        catch (Exception)
        {
            errorMessage = "Gagal memuat data kota dari server. Silakan coba lagi.";
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private void PromptDelete(int id, string name)
    {
        deleteTargetId = id;
        deleteConfirmMessage = $"Apakah Anda yakin ingin menghapus kota <strong>{name}</strong>?";
        showDeleteModal = true;
    }

    private void CancelDelete()
    {
        showDeleteModal = false;
        deleteTargetId = 0;
        deleteConfirmMessage = string.Empty;
    }

    private async Task ConfirmDelete()
    {
        isDeleting = true;
        errorMessage = string.Empty;
        StateHasChanged();

        try
        {
            var result = await CityService.DeleteAsync(deleteTargetId);
            if (result.Success)
            {
                successMessage = result.Message;
                showDeleteModal = false;
                await LoadData();
            }
            else
            {
                errorMessage = result.Message;
                showDeleteModal = false;
                await JSRuntime.InvokeVoidAsync("scrollToTop");
            }
        }
        catch (Exception)
        {
            errorMessage = "Terjadi kesalahan saat menghubungi server untuk menghapus data.";
            showDeleteModal = false;
            await JSRuntime.InvokeVoidAsync("scrollToTop");
        }
        finally
        {
            isDeleting = false;
            StateHasChanged();
        }
    }

    private string FormatCreatedAt(DateTime dt)
    {
        var bulan = new[] { "Jan", "Feb", "Mar", "Apr", "Mei", "Jun", "Jul", "Agt", "Sep", "Okt", "Nov", "Des" };
        var localTime = dt.ToLocalTime();
        return $"{localTime.Day:D2} {bulan[localTime.Month - 1]} {localTime.Year}";
    }
}
