@page "/countries/create"
@inject CountryService CountryService
@inject NavigationManager Navigation
<PageTitle>Buat Negara Baru</PageTitle>

<!-- Section 1: Header -->
<div class="mb-6 flex items-center justify-between">
    <h2 class="text-lg font-semibold text-gray-800 dark:text-white/90">
        Buat Negara Baru
    </h2>
    <a href="/countries"
       class="inline-flex items-center gap-2 rounded-lg border border-gray-300 bg-white px-4 py-2.5 text-sm font-medium text-gray-700 shadow-theme-xs hover:bg-gray-50 hover:text-gray-800 dark:border-gray-700 dark:bg-gray-800 dark:text-gray-400 dark:hover:bg-white/[0.03] dark:hover:text-gray-200">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="19" y1="12" x2="5" y2="12"></line>
            <polyline points="12 19 5 12 12 5"></polyline>
        </svg>
        Kembali
    </a>
</div>

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="mb-6">
        <Alert Type="error" Message="@errorMessage" OnClose="() => errorMessage = string.Empty" />
    </div>
}

<!-- Section 2: Form Input -->
<div class="rounded-2xl border border-gray-200 bg-white dark:border-gray-800 dark:bg-white/[0.03]">
    <form @onsubmit="HandleSubmit" method="POST">
        <div class="space-y-6 p-5 sm:p-6">
            <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
                <div>
                    <label class="mb-1.5 block text-sm font-medium text-gray-700 dark:text-gray-400">Nama</label>
                    <input type="text" required @bind="createRequest.Name"
                           class="h-11 w-full rounded-lg border appearance-none px-4 py-2.5 text-sm shadow-theme-xs placeholder:text-gray-400 focus:outline-none focus:ring-0 border-gray-300 bg-white text-gray-800 focus:border-brand-500 focus:shadow-focus-ring dark:border-gray-700 dark:bg-gray-900 dark:text-white/90 dark:focus:border-brand-500" />
                </div>
                <div>
                    <label class="mb-1.5 block text-sm font-medium text-gray-700 dark:text-gray-400">Tipe Negara</label>
                    <div class="flex h-11 items-center gap-6">
                        <label class="flex items-center gap-2 cursor-pointer">
                            <input type="radio" name="tipeNegara" checked="@(createRequest.IsForeign == false)" @onchange="() => createRequest.IsForeign = false" class="h-4 w-4 border-gray-300 text-brand-500 focus:ring-brand-500 dark:border-gray-600 dark:bg-gray-800 dark:ring-offset-gray-900" />
                            <span class="text-sm font-medium text-gray-700 dark:text-gray-400">Dalam Negeri</span>
                        </label>
                        <label class="flex items-center gap-2 cursor-pointer">
                            <input type="radio" name="tipeNegara" checked="@(createRequest.IsForeign == true)" @onchange="() => createRequest.IsForeign = true" class="h-4 w-4 border-gray-300 text-brand-500 focus:ring-brand-500 dark:border-gray-600 dark:bg-gray-800 dark:ring-offset-gray-900" />
                            <span class="text-sm font-medium text-gray-700 dark:text-gray-400">Luar Negeri</span>
                        </label>
                    </div>
                </div>
            </div>
            
            <!-- Section 3: Button -->
            <div class="flex justify-end pt-4">
                <button type="submit" disabled="@isSubmitting" class="inline-flex items-center gap-2 rounded-lg bg-brand-500 px-6 py-3 text-sm font-medium text-white shadow-theme-xs hover:bg-brand-600 disabled:opacity-50">
                    @if (isSubmitting)
                    {
                        <span class="h-4 w-4 animate-spin rounded-full border-2 border-solid border-white border-t-transparent"></span>
                    }
                    Buat
                </button>
            </div>
        </div>
    </form>
</div>

@code {
    private CountryCreateRequest createRequest = new();
    private bool isSubmitting = false;
    
    private string _errorMessage = string.Empty;
    private string errorMessage
    {
        get => _errorMessage;
        set
        {
            _errorMessage = value;
            if (!string.IsNullOrEmpty(value))
            {
                TriggerAutoCloseError();
            }
        }
    }

    private System.Threading.CancellationTokenSource? _errorCts;

    private async Task HandleSubmit()
    {
        isSubmitting = true;
        errorMessage = string.Empty;
        StateHasChanged();

        try
        {
            var result = await CountryService.CreateAsync(createRequest);
            if (result.Success)
            {
                Navigation.NavigateTo($"/countries?success={Uri.EscapeDataString(result.Message)}", forceLoad: false);
            }
            else
            {
                errorMessage = result.Message;
            }
        }
        catch (Exception)
        {
            errorMessage = "Terjadi kesalahan saat menyimpan data negara.";
        }
        finally
        {
            isSubmitting = false;
            StateHasChanged();
        }
    }

    private async void TriggerAutoCloseError()
    {
        _errorCts?.Cancel();
        _errorCts = new System.Threading.CancellationTokenSource();
        try
        {
            await Task.Delay(5000, _errorCts.Token);
            _errorMessage = string.Empty;
            await InvokeAsync(StateHasChanged);
        }
        catch (TaskCanceledException) { }
    }
}
