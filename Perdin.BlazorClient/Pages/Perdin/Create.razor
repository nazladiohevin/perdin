@page "/perdin/create"
<PageTitle>Buat Pengajuan Perjalanan Dinas</PageTitle>

<div>

    <!-- Section 1: Header -->
    <div class="mb-6 flex items-center justify-between">
        <h2 class="text-lg font-semibold text-gray-800 dark:text-white/90">
            Buat Pengajuan Perjalanan Dinas
        </h2>
        <a href="/perdin"
           class="inline-flex items-center gap-2 rounded-lg border border-gray-300 bg-white px-4 py-2.5 text-sm font-medium text-gray-700 shadow-theme-xs hover:bg-gray-50 hover:text-gray-800 dark:border-gray-700 dark:bg-gray-800 dark:text-gray-400 dark:hover:bg-white/[0.03] dark:hover:text-gray-200">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="19" y1="12" x2="5" y2="12"></line>
                <polyline points="12 19 5 12 12 5"></polyline>
            </svg>
            Kembali
        </a>
    </div>

    <!-- Section 2: Form -->
    <div class="rounded-2xl border border-gray-200 bg-white dark:border-gray-800 dark:bg-white/[0.03]">
        <div class="space-y-6 p-5 sm:p-6">

            <!-- Tanggal Berangkat & Pulang (2 kolom) -->
            <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
                <div>
                    <label class="mb-1.5 block text-sm font-medium text-gray-700 dark:text-gray-400">
                        Tanggal Keberangkatan <span class="text-error-500">*</span>
                    </label>
                    <div class="relative">
                        <input
                            type="date"
                            @bind="tglBerangkat"
                            required
                            onclick="this.showPicker()"
                            class="dark:bg-dark-900 shadow-theme-xs focus:border-brand-300 focus:ring-brand-500/10 dark:focus:border-brand-800 h-11 w-full appearance-none rounded-lg border border-gray-300 bg-transparent bg-none px-4 py-2.5 text-sm text-gray-800 placeholder:text-gray-400 focus:ring-3 focus:outline-hidden dark:border-gray-700 dark:bg-gray-900 dark:text-white/90 dark:placeholder:text-white/30"
                        />
                    </div>
                </div>
                <div>
                    <label class="mb-1.5 block text-sm font-medium text-gray-700 dark:text-gray-400">
                        Tanggal Kepulangan <span class="text-error-500">*</span>
                    </label>
                    <div class="relative">
                        <input
                            type="date"
                            @bind="tglPulang"
                            required
                            onclick="this.showPicker()"
                            class="dark:bg-dark-900 shadow-theme-xs focus:border-brand-300 focus:ring-brand-500/10 dark:focus:border-brand-800 h-11 w-full appearance-none rounded-lg border border-gray-300 bg-transparent bg-none px-4 py-2.5 text-sm text-gray-800 placeholder:text-gray-400 focus:ring-3 focus:outline-hidden dark:border-gray-700 dark:bg-gray-900 dark:text-white/90 dark:placeholder:text-white/30"
                        />
                    </div>
                </div>
            </div>

            <!-- Perjalanan + Checkbox Luar Negeri -->
            <div>
                <p class="mb-3 text-sm font-medium text-gray-800 dark:text-white/90">Perjalanan</p>
                <label
                    for="checkPerjalananLN"
                    class="flex cursor-pointer items-center text-sm font-medium text-gray-700 select-none dark:text-gray-400"
                >
                    <div class="relative">
                        <input
                            type="checkbox"
                            id="checkPerjalananLN"
                            class="sr-only"
                            @bind="isLuarNegeri"
                        />
                        <div
                            class="hover:border-brand-500 dark:hover:border-brand-500 mr-3 flex h-5 w-5 items-center justify-center rounded-md border-[1.25px] @(isLuarNegeri ? "border-brand-500 bg-brand-500" : "bg-transparent border-gray-300 dark:border-gray-700")"
                        >
                            <span class="@(isLuarNegeri ? "" : "opacity-0")">
                                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
                                    <path d="M11.6666 3.5L5.24992 9.91667L2.33325 7" stroke="white" stroke-width="1.94437" stroke-linecap="round" stroke-linejoin="round" />
                                </svg>
                            </span>
                        </div>
                    </div>
                    Perjalanan Luar Negeri
                </label>
            </div>

            <!-- Kota Asal (selalu tampil) -->
            <div>
                <label class="mb-1.5 block text-sm font-medium text-gray-700 dark:text-gray-400">
                    Kota Asal <span class="text-error-500">*</span>
                </label>
                <div class="relative z-20 bg-transparent">
                    <select
                        required
                        class="dark:bg-dark-900 shadow-theme-xs focus:border-brand-300 focus:ring-brand-500/10 dark:focus:border-brand-800 h-11 w-full appearance-none rounded-lg border border-gray-300 bg-transparent bg-none px-4 py-2.5 pr-11 text-sm text-gray-800 placeholder:text-gray-400 focus:ring-3 focus:outline-hidden dark:border-gray-700 dark:bg-gray-900 dark:text-white/90 dark:placeholder:text-white/30"
                    >
                        <option value="" class="text-gray-700 dark:bg-gray-900 dark:text-gray-400">Pilih Kota Asal</option>
                        <option value="jakarta" class="text-gray-700 dark:bg-gray-900 dark:text-gray-400">Jakarta</option>
                        <option value="bandung" class="text-gray-700 dark:bg-gray-900 dark:text-gray-400">Bandung</option>
                        <option value="surabaya" class="text-gray-700 dark:bg-gray-900 dark:text-gray-400">Surabaya</option>
                        <option value="semarang" class="text-gray-700 dark:bg-gray-900 dark:text-gray-400">Semarang</option>
                        <option value="yogyakarta" class="text-gray-700 dark:bg-gray-900 dark:text-gray-400">Yogyakarta</option>
                        <option value="medan" class="text-gray-700 dark:bg-gray-900 dark:text-gray-400">Medan</option>
                        <option value="bali" class="text-gray-700 dark:bg-gray-900 dark:text-gray-400">Bali</option>
                        <option value="malang" class="text-gray-700 dark:bg-gray-900 dark:text-gray-400">Malang</option>
                    </select>
                    <span class="pointer-events-none absolute top-1/2 right-4 z-30 -translate-y-1/2 text-gray-500 dark:text-gray-400">
                        <svg class="stroke-current" width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path d="M4.79175 7.396L10.0001 12.6043L15.2084 7.396" stroke="" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                        </svg>
                    </span>
                </div>
            </div>

            <!-- Kota Tujuan (tampil jika BUKAN luar negeri) -->
            @if (!isLuarNegeri)
            {
                <div>
                    <label class="mb-1.5 block text-sm font-medium text-gray-700 dark:text-gray-400">
                        Kota Tujuan <span class="text-error-500">*</span>
                    </label>
                    <div class="relative z-20 bg-transparent">
                        <select
                            required
                            class="dark:bg-dark-900 shadow-theme-xs focus:border-brand-300 focus:ring-brand-500/10 dark:focus:border-brand-800 h-11 w-full appearance-none rounded-lg border border-gray-300 bg-transparent bg-none px-4 py-2.5 pr-11 text-sm text-gray-800 placeholder:text-gray-400 focus:ring-3 focus:outline-hidden dark:border-gray-700 dark:bg-gray-900 dark:text-white/90 dark:placeholder:text-white/30"
                        >
                            <option value="" class="text-gray-700 dark:bg-gray-900 dark:text-gray-400">Pilih Kota Tujuan</option>
                            <option value="jakarta" class="text-gray-700 dark:bg-gray-900 dark:text-gray-400">Jakarta</option>
                            <option value="bandung" class="text-gray-700 dark:bg-gray-900 dark:text-gray-400">Bandung</option>
                            <option value="surabaya" class="text-gray-700 dark:bg-gray-900 dark:text-gray-400">Surabaya</option>
                            <option value="semarang" class="text-gray-700 dark:bg-gray-900 dark:text-gray-400">Semarang</option>
                            <option value="yogyakarta" class="text-gray-700 dark:bg-gray-900 dark:text-gray-400">Yogyakarta</option>
                            <option value="medan" class="text-gray-700 dark:bg-gray-900 dark:text-gray-400">Medan</option>
                            <option value="bali" class="text-gray-700 dark:bg-gray-900 dark:text-gray-400">Bali</option>
                            <option value="malang" class="text-gray-700 dark:bg-gray-900 dark:text-gray-400">Malang</option>
                        </select>
                        <span class="pointer-events-none absolute top-1/2 right-4 z-30 -translate-y-1/2 text-gray-500 dark:text-gray-400">
                            <svg class="stroke-current" width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <path d="M4.79175 7.396L10.0001 12.6043L15.2084 7.396" stroke="" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                            </svg>
                        </span>
                    </div>
                </div>
            }

            <!-- Negara Tujuan (tampil jika luar negeri) -->
            @if (isLuarNegeri)
            {
                <div>
                    <label class="mb-1.5 block text-sm font-medium text-gray-700 dark:text-gray-400">
                        Negara Tujuan <span class="text-error-500">*</span>
                    </label>
                    <div class="relative z-20 bg-transparent">
                        <select
                            required
                            class="dark:bg-dark-900 shadow-theme-xs focus:border-brand-300 focus:ring-brand-500/10 dark:focus:border-brand-800 h-11 w-full appearance-none rounded-lg border border-gray-300 bg-transparent bg-none px-4 py-2.5 pr-11 text-sm text-gray-800 placeholder:text-gray-400 focus:ring-3 focus:outline-hidden dark:border-gray-700 dark:bg-gray-900 dark:text-white/90 dark:placeholder:text-white/30"
                        >
                            <option value="" class="text-gray-700 dark:bg-gray-900 dark:text-gray-400">Pilih Negara Tujuan</option>
                            <option value="singapore" class="text-gray-700 dark:bg-gray-900 dark:text-gray-400">Singapura</option>
                            <option value="malaysia" class="text-gray-700 dark:bg-gray-900 dark:text-gray-400">Malaysia</option>
                            <option value="thailand" class="text-gray-700 dark:bg-gray-900 dark:text-gray-400">Thailand</option>
                            <option value="japan" class="text-gray-700 dark:bg-gray-900 dark:text-gray-400">Jepang</option>
                            <option value="south-korea" class="text-gray-700 dark:bg-gray-900 dark:text-gray-400">Korea Selatan</option>
                            <option value="australia" class="text-gray-700 dark:bg-gray-900 dark:text-gray-400">Australia</option>
                            <option value="usa" class="text-gray-700 dark:bg-gray-900 dark:text-gray-400">Amerika Serikat</option>
                            <option value="germany" class="text-gray-700 dark:bg-gray-900 dark:text-gray-400">Jerman</option>
                        </select>
                        <span class="pointer-events-none absolute top-1/2 right-4 z-30 -translate-y-1/2 text-gray-500 dark:text-gray-400">
                            <svg class="stroke-current" width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <path d="M4.79175 7.396L10.0001 12.6043L15.2084 7.396" stroke="" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                            </svg>
                        </span>
                    </div>
                </div>
            }

            <!-- Tujuan (Textarea) -->
            <div>
                <label class="mb-1.5 block text-sm font-medium text-gray-700 dark:text-gray-400">
                    Tujuan <span class="text-error-500">*</span>
                </label>
                <textarea
                    placeholder="Masukkan tujuan perjalanan dinas..."
                    rows="5"
                    required
                    class="dark:bg-dark-900 shadow-theme-xs focus:border-brand-300 focus:ring-brand-500/10 dark:focus:border-brand-800 w-full rounded-lg border border-gray-300 bg-transparent px-4 py-2.5 text-sm text-gray-800 placeholder:text-gray-400 focus:ring-3 focus:outline-hidden dark:border-gray-700 dark:bg-gray-900 dark:text-white/90 dark:placeholder:text-white/30"
                ></textarea>
            </div>

        </div>
    </div>

    <!-- Section 3: Total Hari -->
    <div class="mt-6 rounded-2xl border border-gray-200 bg-white p-5 sm:p-6 dark:border-gray-800 dark:bg-white/[0.03]">
        <p class="text-sm font-medium text-gray-500 dark:text-gray-400">Total perjalanan dinas</p>
        <p class="mt-1 text-2xl font-semibold text-gray-800 dark:text-white/90">
            @TotalHari Hari
        </p>
    </div>

    <!-- Section 4: Tombol Submit -->
    <div class="mt-6 flex justify-end">
        <button class="inline-flex items-center justify-center gap-2 rounded-lg bg-brand-500 px-5 py-3 text-sm font-medium text-white shadow-theme-xs hover:bg-brand-600">
            Buat
        </button>
    </div>

</div>

@code {
    private bool isLuarNegeri = false;
    private DateTime? tglBerangkat;
    private DateTime? tglPulang;

    private int TotalHari
    {
        get
        {
            if (tglBerangkat == null || tglPulang == null) return 0;
            var diff = (tglPulang.Value - tglBerangkat.Value).Days;
            return diff > 0 ? diff : 0;
        }
    }
}
