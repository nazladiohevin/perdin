    <div class="mb-6 flex border-b border-gray-200 dark:border-gray-800">
        <button
            @onclick='() => SetActiveTab("baru")'
            class="border-b-2 px-4 py-2.5 text-sm font-medium transition-colors @(activeTab == "baru" ? "border-brand-500 text-brand-500 dark:text-brand-400" : "border-transparent text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-300")"
        >
            Pengajuan Baru
        </button>
        <button
            @onclick='() => SetActiveTab("history")'
            class="border-b-2 px-4 py-2.5 text-sm font-medium transition-colors @(activeTab == "history" ? "border-brand-500 text-brand-500 dark:text-brand-400" : "border-transparent text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-300")"
